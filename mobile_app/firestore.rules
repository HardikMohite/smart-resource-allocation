rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── volunteers/{uid} ───────────────────────────────────────────────────
    // Each volunteer can read and write only their own document.
    // Admins (custom claim) can read all volunteers to show the map.
    match /volunteers/{uid} {
      allow read:  if isOwner(uid)
                   || (isSignedIn() && request.auth.token.admin == true);
      allow write: if isOwner(uid);
    }

    // ── tasks/{taskId} ─────────────────────────────────────────────────────
    // A volunteer can read a task only if it is assigned to them.
    // Only admins can create, update, or delete tasks — EXCEPT that a
    // volunteer may flip the status of their own assigned task from
    // 'assigned' → 'resolved' (and nothing else).
    match /tasks/{taskId} {
      allow read:  if isSignedIn()
                   && (
                        resource.data.assigned_volunteer_uid == request.auth.uid
                        || request.auth.token.admin == true
                      );

      // Full write access for admins.
      allow write: if isSignedIn() && request.auth.token.admin == true;

      // Volunteers may resolve only their own assigned tasks.
      // Permitted transition: status  assigned → resolved
      // All other fields must remain unchanged.
      allow update: if isSignedIn()
                    && resource.data.assigned_volunteer_uid == request.auth.uid
                    && resource.data.status == 'assigned'
                    && request.resource.data.status == 'resolved'
                    // Prevent the client from changing any other field.
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['status']);
    }

    // ── Deny everything else by default ────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
